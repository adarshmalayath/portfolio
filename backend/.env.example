# Shared secret used by auth-service and api-gateway.
JWT_SECRET=replace-this-with-a-long-random-secret-at-least-32-characters

# Google OAuth Web client id used to validate ID tokens in auth-service.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Only these Google accounts can access admin APIs.
ADMIN_ALLOWED_EMAILS=adarshmalayath@gmail.com,adarshmalayath@icloud.com

# DB connection used by content-service
DB_URL=jdbc:postgresql://localhost:5432/portfolio
DB_USER=portfolio_user
DB_PASSWORD=portfolio_pass

# Optional service ports
GATEWAY_PORT=8080
AUTH_SERVICE_PORT=8081
CONTENT_SERVICE_PORT=8082
